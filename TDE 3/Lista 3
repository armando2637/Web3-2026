# 7. Cadastro de 3 alunos
alunos = []

for i in range(3):
    nome = input(f'Digite o nome do {i+1}º aluno: ')
    nota = float(input(f'Digite a nota do {i+1}º aluno: '))
    
    aluno = {
        "nome": nome,
        "nota": nota
    }
    
    alunos.append(aluno)

print(f'Alunos cadastrados:')
for a in alunos:
    print(f'Nome: {a["nome"]} - Nota: {a["nota"]}')


# 8. Média da turma
def media_turma(lista_alunos):
    soma = sum(a["nota"] for a in lista_alunos)
    return soma / len(lista_alunos)

print(f'Média da turma: {media_turma(alunos):.2f}')


# 9. Produto mais caro
def produto_mais_caro(produtos):
    mais_caro = max(produtos, key=produtos.get)
    print(f'Produto mais caro: {mais_caro} - Preço: {produtos[mais_caro]}')

produtos = {
    "arroz": 25,
    "feijão": 10,
    "macarrão": 8
}

produto_mais_caro(produtos)


# 10. Mostrar estoque
def mostrar_estoque(produtos):
    for produto, quantidade in produtos.items():
        print(f'Produto: {produto} - Quantidade: {quantidade}')

estoque = {
    "caneta": 10,
    "caderno": 5,
    "borracha": 7
}

mostrar_estoque(estoque)


# 11. Maior número com *args
def maior_numero(*args):
    return max(args)

print(f'Maior número: {maior_numero(10, 20, 5, 8)}')


# 12. Mostrar dados com **kwargs
def mostrar_dados(**kwargs):
    for chave, valor in kwargs.items():
        print(f'{chave}: {valor}')

mostrar_dados(nome="Armando", idade=20, curso="Programação")
