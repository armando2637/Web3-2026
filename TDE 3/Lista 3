# 1. Soma dos elementos de uma lista
def soma_lista(lista):
    return sum(lista)

lista1 = [1, 2, 3, 4, 5]
print(f'Soma da lista: {soma_lista(lista1)}')


# 2. Maior valor da lista
def maior_valor(lista):
    return max(lista)

print(f'Maior valor da lista: {maior_valor(lista1)}')


# 3. Programa com média
def media(lista):
    return sum(lista) / len(lista)

numeros = []
qtd = int(input("Quantos números deseja digitar? "))

for i in range(qtd):
    num = float(input(f'Digite o {i+1}º número: '))
    numeros.append(num)

print(f'Média dos números: {media(numeros):.2f}')


# 4. Números pares
def numeros_pares(lista):
    return [num for num in lista if num % 2 == 0]

print(f'Números pares: {numeros_pares(lista1)}')


# 5. Contar elementos
def contar_elementos(lista):
    print(f'Quantidade de elementos: {len(lista)}')
    print(f'Maior valor: {max(lista)}')
    print(f'Menor valor: {min(lista)}')

contar_elementos(lista1)


