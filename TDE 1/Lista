# 1. Peça um número e informe se ele é positivo, negativo ou zero
numero = float(input("Digite um número: "))

if numero > 0:
    print(f"{numero} é positivo")
elif numero < 0:
    print(f"{numero} é negativo")
else:
    print(f"{numero} é zero")


# 2. Peça três números e informe qual é o maior
n1 = float(input("Digite o primeiro número: "))
n2 = float(input("Digite o segundo número: "))
n3 = float(input("Digite o terceiro número: "))

maior = n1

if n2 > maior:
    maior = n2

if n3 > maior:
    maior = n3

print(f"O maior número é {maior}")


# 3. Peça um ano e informe se ele é bissexto
ano = int(input("Digite um ano: "))

if (ano % 4 == 0 and ano % 100 != 0) or (ano % 400 == 0):
    print(f"O ano {ano} é bissexto")
else:
    print(f"O ano {ano} não é bissexto")


# 4. Peça o valor de um produto e aplique desconto
valor = float(input("Digite o valor do produto: "))

if valor > 100:
    valor_final = valor * 0.90
elif valor >= 50:
    valor_final = valor * 0.95
else:
    valor_final = valor

print(f"O valor final do produto é {valor_final}")


# 5. Peça um número e verifique se ele é par e positivo
num = int(input("Digite um número: "))

if num % 2 == 0 and num > 0:
    print(f"O número {num} é par e positivo")
else:
    print(f"O número {num} não é par e positivo")


# 6. Peça três lados e verifique se formam um triângulo
a = float(input("Digite o primeiro lado: "))
b = float(input("Digite o segundo lado: "))
c = float(input("Digite o terceiro lado: "))

if a + b > c and a + c > b and b + c > a:
    print(f"Forma um triângulo")

    if a == b and b == c:
        print(f"Triângulo Equilátero")
    elif a == b or a == c or b == c:
        print(f"Triângulo Isósceles")
    else:
        print(f"Triângulo Escaleno")
else:
    print(f"Não forma um triângulo")
