# 8. Menu calculadora
def soma(a, b):
    return a + b

def multiplicacao(a, b):
    return a * b

def divisao(a, b):
    return a / b

def menu_calculadora():
    while True:
        try:
            print(f'\n1 - Soma\n2 - Multiplicação\n3 - Divisão\n4 - Sair')
            opcao = int(input('Escolha: '))
            
            if opcao == 4:
                break

            a = float(input('Digite o primeiro número: '))
            b = float(input('Digite o segundo número: '))

            if opcao == 1:
                print(f'Resultado: {soma(a, b)}')
            elif opcao == 2:
                print(f'Resultado: {multiplicacao(a, b)}')
            elif opcao == 3:
                print(f'Resultado: {divisao(a, b)}')
            else:
                print(f'Opção inválida!')
        except ValueError:
            print(f'Erro! Entrada inválida.')
        except ZeroDivisionError:
            print(f'Erro! Divisão por zero.')
        finally:
            print(f'Ciclo do menu executado')

menu_calculadora()


# 9. Ler arquivo números
def ler_arquivo_numeros(nome):
    soma = 0
    try:
        with open(nome, 'r') as arq:
            for linha in arq:
                try:
                    soma += float(linha.strip())
                except ValueError:
                    print(f'Linha inválida ignorada')
    except FileNotFoundError:
        print(f'Arquivo não encontrado!')
    else:
        print(f'Soma dos números: {soma}')

ler_arquivo_numeros('numeros.txt')


# 10. Leia número
def leia_numero(tipo):
    while True:
        try:
            valor = input(f'Digite um valor ({tipo}): ')
            if tipo == "int":
                valor = int(valor)
            elif tipo == "float":
                valor = float(valor)
            else:
                print(f'Tipo inválido!')
                continue
        except ValueError:
            print(f'Erro! Valor inválido.')
        else:
            return valor
        finally:
            print(f'Tentativa realizada')

print(f'Número lido: {leia_numero("int")}')


# 11. Fatorial
def fatorial(n):
    resultado = 1
    for i in range(1, n+1):
        resultado *= i
    return resultado

print(f'Fatorial: {fatorial(5)}')


