# 1. Ler inteiro com tratamento
def ler_inteiro(msg):
    try:
        valor = int(input(msg))
    except ValueError:
        print(f'Erro! Digite um número inteiro válido.')
    else:
        return valor
    finally:
        print(f'Tentativa de leitura finalizada')

# Exemplo:
num = ler_inteiro('Digite um número inteiro: ')
print(f'Valor digitado: {num}')


# 2. Divisão segura
def divisao_segura(a, b):
    try:
        resultado = a / b
    except ZeroDivisionError:
        print(f'Erro! Divisão por zero.')
    else:
        print(f'Resultado: {resultado}')
    finally:
        print(f'Operação de divisão encerrada')

divisao_segura(10, 2)
divisao_segura(10, 0)


# 3. Ler lista
def ler_lista():
    lista = []
    while True:
        entrada = input('Digite um número ou "fim": ')
        if entrada.lower() == 'fim':
            break
        try:
            num = float(entrada)
        except ValueError:
            print(f'Valor inválido!')
        else:
            lista.append(num)
    return lista

lista = ler_lista()
print(f'Lista final: {lista}')


# 4. Buscar elemento
def buscar_elemento(lista, indice):
    try:
        valor = lista[indice]
    except IndexError:
        print(f'Índice inválido!')
    else:
        print(f'Valor encontrado: {valor}')
    finally:
        print(f'Busca finalizada')

buscar_elemento([1, 2, 3], 1)
buscar_elemento([1, 2, 3], 10)


# 5. Abrir arquivo seguro
def abrir_arquivo_seguro(nome):
    try:
        with open(nome, 'r') as arq:
            conteudo = arq.read()
    except FileNotFoundError:
        print(f'Arquivo não encontrado!')
    else:
        print(f'Conteúdo do arquivo:\n{conteudo}')
    finally:
        print(f'Processo de arquivo finalizado')

abrir_arquivo_seguro('teste.txt')


# 6. Calcular média
def calcular_media():
    lista = []
    while len(lista) < 5:
        try:
            num = float(input(f'Digite um número: '))
        except ValueError:
            print(f'Erro! Digite um número válido.')
        else:
            lista.append(num)
    return sum(lista) / len(lista)

print(f'Média: {calcular_media():.2f}')


